@startuml
title <size:24>Deployment View: ACGS Platform - Production</size>\n<size:24>Production deployment topology</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Deployment>

Deployment_Node(Production.CloudflareEdge, "Cloudflare Edge", $type="Cloudflare Workers", $descr="Global edge network", $tags="", $link="") {
  Container(Production.CloudflareEdge.GovernanceProxy_1, "Governance Proxy", $techn="Cloudflare Worker / TypeScript", $descr="Edge-level request/response governance validation with WASM validator. Intercepts LLM API calls and attaches governance proof headers.", $tags="", $link="")
  Deployment_Node(Production.CloudflareEdge.KVNamespace, "KV Namespace", $type="Cloudflare KV", $descr="Constitution config storage", $tags="", $link="")
  Deployment_Node(Production.CloudflareEdge.D1Database, "D1 Database", $type="Cloudflare D1", $descr="Audit log persistence", $tags="", $link="")
}

Deployment_Node(Production.ApplicationServer, "Application Server", $type="Linux / PM2", $descr="PM2-managed services", $tags="", $link="") {
  Deployment_Node(Production.ApplicationServer.GatewayProcess, "Gateway Process", $type="Uvicorn", $descr="Port 8080", $tags="", $link="") {
    Container(Production.ApplicationServer.GatewayProcess.APIGateway_1, "API Gateway", $techn="FastAPI / Python", $descr="Unified ingress with JWT auth, rate limiting (Redis-backed), SSO (OIDC/SAML), PQC enforcement, autonomy tier control, and API versioning.", $tags="", $link="")
  }

  Deployment_Node(Production.ApplicationServer.AgentBusProcess, "Agent Bus Process", $type="Uvicorn", $descr="Port 8000", $tags="", $link="") {
    Container(Production.ApplicationServer.AgentBusProcess.EnhancedAgentBus_1, "Enhanced Agent Bus", $techn="FastAPI / Python", $descr="Core messaging platform with 80+ subsystems: message routing, batch processing, constitutional validation, MACI enforcement, and multi-agent orchestration.", $tags="", $link="")
  }

  Deployment_Node(Production.ApplicationServer.SupportingServices, "Supporting Services", $type="Uvicorn", $descr="Ports 8082-8403", $tags="", $link="") {
    Container(Production.ApplicationServer.SupportingServices.AnalyticsAPI_1, "Analytics API", $techn="FastAPI / Python", $descr="Governance analytics, anomaly detection, and reporting.", $tags="", $link="")
    Container(Production.ApplicationServer.SupportingServices.ArchitectureFitness_1, "Architecture Fitness", $techn="FastAPI / Python", $descr="Weekly governance fitness reports derived from Prometheus metrics.", $tags="", $link="")
    Container(Production.ApplicationServer.SupportingServices.x402Governance_1, "x402 Governance", $techn="FastAPI / Python", $descr="Micropayment-gated governance scoring service.", $tags="", $link="")
    Container(Production.ApplicationServer.SupportingServices.EUAIActTool_1, "EU AI Act Tool", $techn="FastAPI / Python", $descr="Self-service EU AI Act compliance risk classification.", $tags="", $link="")
  }

  Deployment_Node(Production.ApplicationServer.LLMServer, "LLM Server", $type="mistral.rs", $descr="Port 8090", $tags="", $link="") {
    Container(Production.ApplicationServer.LLMServer.MistralLLM_1, "Mistral LLM", $techn="mistral.rs / Rust", $descr="Self-hosted OpenAI-compatible inference server.", $tags="", $link="")
  }

  Container(Production.ApplicationServer.ACGSLiteEngine_1, "ACGS-Lite Engine", $techn="Python / Rust (PyO3)", $descr="Constitutional validation engine with Python + optional Rust/PyO3 backend (560ns P50). Core API: Constitution.from_yaml() + GovernedAgent().", $tags="", $link="")
  Container(Production.ApplicationServer.MCPServer_1, "MCP Server", $techn="Python", $descr="Model Context Protocol server exposing governance tools (validate_action, get_constitution, get_audit_log, governance_stats) to Claude, VS Code, Cursor.", $tags="", $link="")
}

Deployment_Node(Production.DataLayer, "Data Layer", $type="", $descr="Managed infrastructure", $tags="", $link="") {
  Deployment_Node(Production.DataLayer.PostgreSQLServer, "PostgreSQL Server", $type="PostgreSQL 15", $descr="Port 5432", $tags="", $link="") {
    ContainerDb(Production.DataLayer.PostgreSQLServer.PostgreSQL_1, "PostgreSQL", $techn="PostgreSQL 15", $descr="Workflow persistence, audit logs, governance state.", $tags="", $link="")
  }

  Deployment_Node(Production.DataLayer.RedisServer, "Redis Server", $type="Redis 7", $descr="Port 6379", $tags="", $link="") {
    ContainerDb(Production.DataLayer.RedisServer.Redis_1, "Redis", $techn="Redis 7", $descr="Rate limiting, session cache, governance state cache.", $tags="", $link="")
  }

}

Rel(Production.ApplicationServer.GatewayProcess.APIGateway_1, Production.DataLayer.RedisServer.Redis_1, "Rate limiting and session lookup", $techn="Redis Protocol", $tags="", $link="")
Rel(Production.ApplicationServer.AgentBusProcess.EnhancedAgentBus_1, Production.DataLayer.RedisServer.Redis_1, "Caches governance state", $techn="Redis Protocol", $tags="", $link="")
Rel(Production.CloudflareEdge.GovernanceProxy_1, Production.ApplicationServer.GatewayProcess.APIGateway_1, "Proxies validated requests to", $techn="HTTPS", $tags="", $link="")
Rel(Production.ApplicationServer.GatewayProcess.APIGateway_1, Production.ApplicationServer.AgentBusProcess.EnhancedAgentBus_1, "Proxies governance/messaging requests to", $techn="REST/JSON", $tags="", $link="")
Rel(Production.ApplicationServer.LLMServer.MistralLLM_1, Production.CloudflareEdge.GovernanceProxy_1, "Served behind governance proxy", $techn="HTTPS", $tags="", $link="")
Rel(Production.ApplicationServer.AgentBusProcess.EnhancedAgentBus_1, Production.ApplicationServer.ACGSLiteEngine_1, "Validates messages against constitution", $techn="Python API", $tags="", $link="")
Rel(Production.ApplicationServer.SupportingServices.x402Governance_1, Production.ApplicationServer.ACGSLiteEngine_1, "Scores governance via", $techn="Python API", $tags="", $link="")
Rel(Production.ApplicationServer.SupportingServices.EUAIActTool_1, Production.ApplicationServer.ACGSLiteEngine_1, "Classifies risk via", $techn="Python API", $tags="", $link="")
Rel(Production.ApplicationServer.ACGSLiteEngine_1, Production.ApplicationServer.MCPServer_1, "Exposes validation tools via", $techn="MCP Protocol", $tags="", $link="")
Rel(Production.ApplicationServer.AgentBusProcess.EnhancedAgentBus_1, Production.DataLayer.PostgreSQLServer.PostgreSQL_1, "Persists workflows and audit logs", $techn="asyncpg", $tags="", $link="")
Rel(Production.ApplicationServer.SupportingServices.AnalyticsAPI_1, Production.DataLayer.PostgreSQLServer.PostgreSQL_1, "Queries governance data from", $techn="asyncpg", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml