@startuml
title <size:24>Component View: ACGS Platform - Enhanced Agent Bus</size>\n<size:24>Enhanced Agent Bus internal components</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Component>

System_Boundary("ACGSPlatform_boundary", "ACGS Platform", $tags="") {
  Container_Boundary("ACGSPlatform.EnhancedAgentBus_boundary", "Enhanced Agent Bus", $tags="") {
    Component(ACGSPlatform.EnhancedAgentBus.MessageProcessor, "Message Processor", $techn="Python", $descr="Core message routing and processing pipeline.", $tags="", $link="")
    Component(ACGSPlatform.EnhancedAgentBus.BatchProcessor, "Batch Processor", $techn="Python", $descr="Batch message processing with governance middleware.", $tags="", $link="")
    Component(ACGSPlatform.EnhancedAgentBus.MACIEnforcer, "MACI Enforcer", $techn="Python / Middleware", $descr="Proposer/Validator/Executor separation of powers enforcement.", $tags="", $link="")
    Component(ACGSPlatform.EnhancedAgentBus.OPAClient, "OPA Client", $techn="Python", $descr="Policy evaluation against Open Policy Agent.", $tags="", $link="")
    Component(ACGSPlatform.EnhancedAgentBus.CircuitBreaker, "Circuit Breaker", $techn="Python", $descr="Fault tolerance for messaging subsystem.", $tags="", $link="")
    Component(ACGSPlatform.EnhancedAgentBus.WorkflowExecutor, "Workflow Executor", $techn="Python", $descr="Durable saga-based workflow persistence and execution.", $tags="", $link="")
    Component(ACGSPlatform.EnhancedAgentBus.DeliberationLayer, "Deliberation Layer", $techn="Python", $descr="Multi-agent consensus and conflict resolution.", $tags="", $link="")
    Component(ACGSPlatform.EnhancedAgentBus.PolicyCopilot, "Policy Copilot", $techn="Python", $descr="AI-assisted policy suggestion and review.", $tags="", $link="")
  }

}

SHOW_LEGEND(true)
hide stereotypes
@enduml