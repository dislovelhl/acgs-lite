@startuml
title <size:24>Container View: ACGS Platform</size>\n<size:24>Container diagram - internal services and data stores</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>

Person(AIDeveloper, "AI Developer", $descr="Integrates governance into AI agents via SDK or API.", $tags="", $link="")
Person(ComplianceOfficer, "Compliance Officer", $descr="Monitors governance posture and regulatory alignment.", $tags="", $link="")
Person(PlatformAdmin, "Platform Admin", $descr="Manages constitutional rules, SSO, and system configuration.", $tags="", $link="")
System(OpenPolicyAgent, "Open Policy Agent", $descr="Policy decision engine for rule evaluation.", $tags="", $link="")
System(ApacheKafka, "Apache Kafka", $descr="Event streaming for analytics pipeline.", $tags="", $link="")
System(Prometheus, "Prometheus", $descr="Metrics collection and monitoring.", $tags="", $link="")
System(LLMProviders, "LLM Providers", $descr="OpenAI, Anthropic, and other LLM APIs.", $tags="", $link="")
System(CloudflareKV, "Cloudflare KV", $descr="Edge key-value store for constitution configs.", $tags="", $link="")
System(CloudflareD1, "Cloudflare D1", $descr="Edge SQLite database for audit logs.", $tags="", $link="")

System_Boundary("ACGSPlatform_boundary", "ACGS Platform", $tags="") {
  Container(ACGSPlatform.EnhancedAgentBus, "Enhanced Agent Bus", $techn="FastAPI / Python", $descr="Core messaging platform with 80+ subsystems: message routing, batch processing, constitutional validation, MACI enforcement, and multi-agent orchestration.", $tags="", $link="")
  Container(ACGSPlatform.ACGSLiteEngine, "ACGS-Lite Engine", $techn="Python / Rust (PyO3)", $descr="Constitutional validation engine with Python + optional Rust/PyO3 backend (560ns P50). Core API: Constitution.from_yaml() + GovernedAgent().", $tags="", $link="")
  Container(ACGSPlatform.MCPServer, "MCP Server", $techn="Python", $descr="Model Context Protocol server exposing governance tools (validate_action, get_constitution, get_audit_log, governance_stats) to Claude, VS Code, Cursor.", $tags="", $link="")
  Container(ACGSPlatform.AnalyticsAPI, "Analytics API", $techn="FastAPI / Python", $descr="Governance analytics, anomaly detection, and reporting.", $tags="", $link="")
  Container(ACGSPlatform.ArchitectureFitness, "Architecture Fitness", $techn="FastAPI / Python", $descr="Weekly governance fitness reports derived from Prometheus metrics.", $tags="", $link="")
  Container(ACGSPlatform.x402Governance, "x402 Governance", $techn="FastAPI / Python", $descr="Micropayment-gated governance scoring service.", $tags="", $link="")
  Container(ACGSPlatform.EUAIActTool, "EU AI Act Tool", $techn="FastAPI / Python", $descr="Self-service EU AI Act compliance risk classification.", $tags="", $link="")
  Container(ACGSPlatform.MistralLLM, "Mistral LLM", $techn="mistral.rs / Rust", $descr="Self-hosted OpenAI-compatible inference server.", $tags="", $link="")
  ContainerDb(ACGSPlatform.PostgreSQL, "PostgreSQL", $techn="PostgreSQL 15", $descr="Workflow persistence, audit logs, governance state.", $tags="", $link="")
  ContainerDb(ACGSPlatform.Redis, "Redis", $techn="Redis 7", $descr="Rate limiting, session cache, governance state cache.", $tags="", $link="")
  Container(ACGSPlatform.GovernanceProxy, "Governance Proxy", $techn="Cloudflare Worker / TypeScript", $descr="Edge-level request/response governance validation with WASM validator. Intercepts LLM API calls and attaches governance proof headers.", $tags="", $link="")
  Container(ACGSPlatform.APIGateway, "API Gateway", $techn="FastAPI / Python", $descr="Unified ingress with JWT auth, rate limiting (Redis-backed), SSO (OIDC/SAML), PQC enforcement, autonomy tier control, and API versioning.", $tags="", $link="")
}

Rel(AIDeveloper, ACGSPlatform.MCPServer, "Validates actions via MCP tools", $techn="MCP Protocol", $tags="", $link="")
Rel(AIDeveloper, ACGSPlatform.GovernanceProxy, "Routes LLM calls through", $techn="HTTPS", $tags="", $link="")
Rel(ComplianceOfficer, ACGSPlatform.APIGateway, "Reviews compliance dashboards", $techn="HTTPS", $tags="", $link="")
Rel(PlatformAdmin, ACGSPlatform.APIGateway, "Configures SSO, autonomy tiers, constitutional rules", $techn="HTTPS", $tags="", $link="")
Rel(ACGSPlatform.GovernanceProxy, ACGSPlatform.APIGateway, "Proxies validated requests to", $techn="HTTPS", $tags="", $link="")
Rel(ACGSPlatform.APIGateway, ACGSPlatform.EnhancedAgentBus, "Proxies governance/messaging requests to", $techn="REST/JSON", $tags="", $link="")
Rel(ACGSPlatform.APIGateway, ACGSPlatform.Redis, "Rate limiting and session lookup", $techn="Redis Protocol", $tags="", $link="")
Rel(ACGSPlatform.EnhancedAgentBus, ACGSPlatform.ACGSLiteEngine, "Validates messages against constitution", $techn="Python API", $tags="", $link="")
Rel(ACGSPlatform.EnhancedAgentBus, OpenPolicyAgent, "Evaluates policies against", $techn="REST/JSON", $tags="", $link="")
Rel(ACGSPlatform.EnhancedAgentBus, ACGSPlatform.PostgreSQL, "Persists workflows and audit logs", $techn="asyncpg", $tags="", $link="")
Rel(ACGSPlatform.EnhancedAgentBus, ACGSPlatform.Redis, "Caches governance state", $techn="Redis Protocol", $tags="", $link="")
Rel(ACGSPlatform.EnhancedAgentBus, ApacheKafka, "Publishes governance events to", $techn="Kafka Protocol", $tags="", $link="")
Rel(ACGSPlatform.ACGSLiteEngine, ACGSPlatform.MCPServer, "Exposes validation tools via", $techn="MCP Protocol", $tags="", $link="")
Rel(ACGSPlatform.GovernanceProxy, LLMProviders, "Proxies validated requests to upstream", $techn="HTTPS", $tags="", $link="")
Rel(ACGSPlatform.GovernanceProxy, CloudflareKV, "Reads constitution configs from", $techn="KV API", $tags="", $link="")
Rel(ACGSPlatform.GovernanceProxy, CloudflareD1, "Writes audit logs to", $techn="D1 API", $tags="", $link="")
Rel(ACGSPlatform.AnalyticsAPI, ApacheKafka, "Consumes governance events from", $techn="Kafka Protocol", $tags="", $link="")
Rel(ACGSPlatform.AnalyticsAPI, ACGSPlatform.PostgreSQL, "Queries governance data from", $techn="asyncpg", $tags="", $link="")
Rel(ACGSPlatform.ArchitectureFitness, Prometheus, "Pulls governance metrics from", $techn="PromQL", $tags="", $link="")
Rel(ACGSPlatform.x402Governance, ACGSPlatform.ACGSLiteEngine, "Scores governance via", $techn="Python API", $tags="", $link="")
Rel(ACGSPlatform.EUAIActTool, ACGSPlatform.ACGSLiteEngine, "Classifies risk via", $techn="Python API", $tags="", $link="")
Rel(ACGSPlatform.MistralLLM, ACGSPlatform.GovernanceProxy, "Served behind governance proxy", $techn="HTTPS", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml