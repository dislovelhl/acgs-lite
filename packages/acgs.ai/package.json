{
	"name": "acgs.ai",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "env -u NO_COLOR playwright test",
		"test:e2e:fast": "npx @lightpanda/browser serve & sleep 1 && LIGHTPANDA_WS_ENDPOINT=ws://127.0.0.1:9222 env -u NO_COLOR playwright test --project=lightpanda; kill %1 2>/dev/null || true",
		"lint": "eslint .",
		"format": "prettier --plugin prettier-plugin-svelte --write ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@lightpanda/browser": "^1.0.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@testing-library/svelte": "^5.3.1",
		"@types/d3": "^7.4.3",
		"@types/node": "^25.5.0",
		"@vitest/browser-playwright": "^4.1.0",
		"eslint": "^10.0.3",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"jsdom": "^29.0.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"@threlte/core": "^8.5.3",
		"@threlte/extras": "^9.13.0",
		"@threlte/theatre": "^3.2.1",
		"@types/three": "^0.183.1",
		"@xyflow/svelte": "^1.5.1",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"d3": "^7.9.0",
		"layerchart": "^1.0.13",
		"lucide-svelte": "^0.577.0",
		"tailwind-merge": "^3.5.0",
		"three": "^0.183.2"
	}
}
