# Development Dockerfile for Enhanced Agent Bus
FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Install Python dependencies
RUN pip install --no-cache-dir \
    fastapi==0.115.6 \
    uvicorn[standard]==0.32.1 \
    redis>=5.0.0 \
    httpx>=0.27.0 \
    pydantic>=2.12.1 \
    litellm>=1.61.6 \
    slowapi>=0.1.9 \
    msgpack>=1.0.0 \
    numpy \
    asyncpg>=0.29.0 \
    prometheus-client>=0.20.0 \
    orjson>=3.9.0 \
    aiohttp>=3.9.0 \
    pytest>=8.0.0 \
    pytest-asyncio>=0.23.0 \
    pybreaker \
    aiofiles>=23.0.0 \
    cachetools>=5.0.0 \
    sqlalchemy>=2.0.0 \
    aiokafka>=0.10.0 \
    cryptography>=41.0.0 \
    PyJWT>=2.8.0 \
    jsonschema>=4.0.0 \
    psutil>=5.9.0 \
    psycopg2-binary>=2.9.0 \
    opentelemetry-api>=1.20.0 \
    opentelemetry-sdk>=1.20.0 \
    opentelemetry-instrumentation-fastapi>=0.40b0 \
    python-jose[cryptography]>=3.3.0 \
    python-multipart>=0.0.9 \
    passlib[bcrypt]>=1.7.4 \
    email-validator>=2.0.0

# Copy source code to the correct package path
RUN mkdir -p /app/enhanced_agent_bus
COPY packages/enhanced_agent_bus/ /app/enhanced_agent_bus/

# Set PYTHONPATH so 'enhanced_agent_bus' is importable directly
ENV PYTHONPATH=/app

# Expose port
EXPOSE 8000

# Default command
CMD ["python", "-m", "uvicorn", "enhanced_agent_bus.api.app:app", "--host", "0.0.0.0", "--port", "8000", "--log-level", "info"]
