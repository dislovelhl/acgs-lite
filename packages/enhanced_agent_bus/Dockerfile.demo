# Demo Dockerfile for Enhanced Agent Bus
# Build context: repository root (to include src/core/shared/)
FROM python:3.11-slim

# hadolint ignore=DL3008
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/acgs

# Install Python dependencies and copy source preserving package hierarchy
RUN pip install --no-cache-dir \
    fastapi==0.115.6 \
    "uvicorn[standard]==0.32.1" \
    "redis>=5.0.0" \
    "httpx>=0.27.0" \
    "pydantic[email]>=2.12.1" \
    "litellm>=1.61.6" \
    "slowapi>=0.1.9" \
    "msgpack>=1.0.0" \
    numpy \
    "asyncpg>=0.29.0" \
    "prometheus-client>=0.20.0" \
    "orjson>=3.9.0" \
    "aiohttp>=3.9.0" \
    "aiofiles>=23.0.0" \
    "cryptography>=42.0.0" \
    "python-jose[cryptography]>=3.3.0" \
    pybreaker

# hadolint ignore=DL3059
RUN mkdir -p /opt/acgs/enhanced_agent_bus
COPY packages/enhanced_agent_bus/ /opt/acgs/enhanced_agent_bus/

# PYTHONPATH set to /opt/acgs so 'enhanced_agent_bus' is importable directly
ENV PYTHONPATH="/opt/acgs"

EXPOSE 8000
CMD ["uvicorn", "enhanced_agent_bus.api.app:app", "--host", "0.0.0.0", "--port", "8000", "--log-level", "info"]
