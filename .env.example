# ACGS-Lite test environment — placeholder values
# Copy to .env.test and source before running tests:
#   cp .env.test.example .env.test
#   source .env.test
#
# All tests use InMemory* stubs internally — no real keys are needed.
# These placeholders satisfy import-time validation in optional deps.

# OpenAI (placeholder — tests use InMemoryLLMBackend)
OPENAI_API_KEY=test-key-for-unit-tests

# Anthropic (placeholder — tests use InMemoryLLMBackend)
ANTHROPIC_API_KEY=test-key-for-unit-tests

# Google (placeholder — tests use InMemoryLLMBackend)
GOOGLE_API_KEY=test-key-for-unit-tests

# Governance engine (set automatically by tests via constitutional_hash fixture)
# CONSTITUTIONAL_HASH is pinned in pyproject.toml — do not change without reviewing tests
CONSTITUTIONAL_HASH=608508a9bd224290
