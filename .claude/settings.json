{
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -m ruff:*)",
      "Bash(python -m mypy:*)",
      "Bash(ruff:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(uv:*)",
      "Bash(npm test:*)",
      "Bash(npx vitest:*)",
      "Bash(npm run:*)",
      "Bash(pnpm:*)",
      "Bash(maturin:*)",
      "Bash(cargo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pm2:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git stash:*)",
      "Bash(git reset --hard:*)",
      "Bash(DROP TABLE:*)",
      "Bash(DROP DATABASE:*)",
      "Bash(sudo:*)",
      "Bash(eval:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | bash:*)",
      "Bash(chmod 777:*)",
      "Bash(pip install --break-system-packages:*)"
    ]
  },
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "# Validate completed work with Codex readiness checks.\nif ! command -v make >/dev/null 2>&1; then\n    exit 0\nfi\n\nif [ ! -f \"Makefile\" ]; then\n    exit 0\nfi\n\nmake codex-doctor >/dev/null 2>&1 || exit 0",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
